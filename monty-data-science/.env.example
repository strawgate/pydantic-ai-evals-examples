# === LLM Provider (Anthropic or compatible proxy) ===
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Or use a MiniMax / proxy that speaks the Anthropic API:
# MINIMAX_API_KEY=sk-...
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# === Eval Config ===
# Model used by the agent (and by LLMJudge if not overridden)
# MODEL=claude-sonnet-4-20250514
# MAX_CONCURRENCY=1   # data-science evals are sequential by default (heavy CodeMode runs)

# === Logfire (optional) ===
# Set LOGFIRE_TOKEN to send traces; the same token is reused as LOGFIRE_API_KEY
# for managed variables / datasets API.
# LOGFIRE_TOKEN=...
# LOGFIRE_SERVICE_NAME=monty-data-science-evals

# === Managed Variable (optional) ===
# When set, the agent resolves its system prompt from this Logfire managed
# variable instead of the hardcoded default. Logfire's optimizer will then
# evolve the prompt across eval runs that emit traces tagged with the
# variable version.
# LOGFIRE_VAR_SYSTEM_PROMPT=system_prompt_data_science
