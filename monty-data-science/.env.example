# ============================================================================
# CONTINUOUS-IMPROVEMENT DEMO (`uv run demo`)  — see DEMO.md
# ============================================================================
# Three secrets. Copy this file to `.env` and fill them in.

# 1. Model access — the agent runs via the Pydantic AI Gateway.
PYDANTIC_AI_GATEWAY_API_KEY=pylf_v2_...

# 2. Trace ingestion — a Logfire project WRITE token (sends spans).
LOGFIRE_TOKEN=pylf_v1_...

# 3. Managed-variable access — a Logfire USER API KEY (NOT a write token).
#    Needs project permissions `read_variables` (runtime: pick up the
#    optimized prompt) and `write_variables` (setup: seed the variable).
#    Org members already have both, so a personal API key works.
LOGFIRE_API_KEY=pylf_...

# Optional demo knobs (defaults in parentheses):
# MODEL=gateway/anthropic:claude-sonnet-4-5
# DEMO_WORKERS=3                 # concurrent request workers
# DEMO_MIN_DELAY=2               # min seconds between a worker's requests
# DEMO_MAX_DELAY=8               # max seconds between a worker's requests
# DEMO_REQUEST_LIMIT=30          # per-run model-request cap
# LOGFIRE_SERVICE_NAME=monty-data-science

# ============================================================================
# EVAL HARNESS (`make eval*`) — separate from the demo, optional
# ============================================================================
# The eval path uses an Anthropic-style key directly (not the gateway):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Or a MiniMax / Anthropic-compatible proxy:
# MINIMAX_API_KEY=sk-...
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic
# MAX_CONCURRENCY=1
# LOGFIRE_VAR_SYSTEM_PROMPT=system_prompt_data_science
